{
  "name": "feathershot",
  "version": "1.1.3",
  "description": "Lightweight screenshot annotations — fast and distraction-free.",
  "repository": {
    "type": "git",
    "url": "https://github.com/KurtStevenK/FeatherShot.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "build:all": "electron-builder --win --linux --publish never"
  },
  "build": {
    "appId": "com.kainzmayer.feathershot",
    "productName": "FeatherShot",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "renderer/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Graphics",
      "synopsis": "Lightweight screenshot annotations",
      "description": "FeatherShot — capture, annotate, and share screenshots instantly."
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "screenshot-desktop": "^1.15.0"
  },
  "author": {
    "name": "Kurt Steven Kainzmayer",
    "email": "kurt.steven.kainzmyer@gmail.com"
  },
  "license": "MIT"
}